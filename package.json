{
  "name": "manim-vscode",
  "displayName": "Manim VSCode",
  "description": "",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      { "command": "manim.runScene",                "title": "Manim: Run Scene" },
      { "command": "manim.exit",                    "title": "Manim: Exit" },
      { "command": "manim.checkpointPaste",         "title": "Manim: Checkpoint Paste" },
      { "command": "manim.recordedCheckpointPaste", "title": "Manim: Recorded Checkpoint Paste" },
      { "command": "manim.skippedCheckpointPaste",  "title": "Manim: Skipped Checkpoint Paste" },
      { "command": "manim.reload",                  "title": "Manim: Reload" },
      { "command": "manim.render",                  "title": "Manim: Render" },
      { "command": "manim.toggleIPython",           "title": "Manim: Toggle IPython Mode" }
    ],
    "keybindings": [
      { "command": "manim.runScene",                "key": "ctrl+shift+m", "when": "editorTextFocus" },
      { "command": "manim.reload",                  "key": "ctrl+shift+j", "when": "editorTextFocus" },
      { "command": "manim.checkpointPaste",         "key": "ctrl+p", "when": "editorTextFocus" },
      { "command": "manim.skippedCheckpointPaste",  "key": "alt+p",  "when": "editorTextFocus" },
      { "command": "manim.recordedCheckpointPaste", "key": "ctrl+alt+p", "when": "editorTextFocus" },
      { "command": "manim.exit",                    "key": "ctrl+e", "when": "editorTextFocus" }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "repository": {
      "type": "git",
      "url": "https://github.com/p2perrault/manim-vscode.git"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.19",
    "@types/vscode": "^1.120.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
